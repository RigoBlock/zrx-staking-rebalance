# Ethereum RPC endpoint. Used for reading chain state and sending transactions.
# Can also be supplied via --rpc-url on each command.
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Optional: Safe Transaction Service URL (defaults to Safe's mainnet service).
SAFE_TX_SERVICE_URL=https://safe-transaction-mainnet.safe.global

# Optional: chain id (defaults to 1 = Ethereum mainnet).
CHAIN_ID=1
