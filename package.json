{
  "name": "zrx-staking-rebalance",
  "version": "0.1.0",
  "private": false,
  "description": "Terminal utility to reallocate ZRX stake across specific staking pools and optionally migrate to wZRX governance.",
  "scripts": {
    "build": "forge build",
    "lint": "forge lint",
    "test:foundry": "forge test",
    "op": "./sh/op.sh",
    "op:stake-delegate": "./sh/stake-and-delegate.sh --broadcast",
    "op:sim:stake-delegate": "./sh/stake-and-delegate.sh",
    "op:delegate-equal": "./sh/delegate-equal.sh --broadcast",
    "op:sim:delegate-equal": "./sh/delegate-equal.sh",
    "op:undelegate": "./sh/redelegate.sh --broadcast undelegate-all",
    "op:sim:undelegate": "./sh/redelegate.sh undelegate-all",
    "op:redelegate": "./sh/redelegate.sh --broadcast redelegate-all",
    "op:sim:redelegate": "./sh/redelegate.sh redelegate-all",
    "op:rebalance": "./sh/redelegate.sh --broadcast redelegate-amount",
    "op:sim:rebalance": "./sh/redelegate.sh redelegate-amount",
    "op:wrap:liquid": "./sh/wrap-governance.sh --broadcast liquid",
    "op:sim:wrap:liquid": "./sh/wrap-governance.sh liquid",
    "op:wrap:full": "./sh/wrap-governance.sh --broadcast full",
    "op:sim:wrap:full": "./sh/wrap-governance.sh full",
    "op:wrap:exclude-pools": "./sh/wrap-governance.sh --broadcast exclude-pools",
    "op:sim:wrap:exclude-pools": "./sh/wrap-governance.sh exclude-pools",
    "op:unstake": "./sh/wrap-governance.sh --broadcast unstake",
    "op:sim:unstake": "./sh/wrap-governance.sh unstake",
    "op:treasury:propose": "./sh/treasury.sh --broadcast propose",
    "op:sim:treasury:propose": "./sh/treasury.sh propose",
    "op:treasury:execute": "./sh/treasury.sh --broadcast execute",
    "op:sim:treasury:execute": "./sh/treasury.sh execute"
  }
}
