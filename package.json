{
  "name": "zrx-staking-rebalance",
  "version": "0.1.0",
  "private": true,
  "description": "Terminal utility to reallocate ZRX stake across specific staking pools and optionally migrate to wZRX governance.",
  "type": "module",
  "scripts": {
    "build": "forge build",
    "lint": "forge lint",
    "op": "./sh/op.sh",
    "op:stake-delegate": "./sh/stake-and-delegate.sh",
    "op:sim:stake-delegate": "DRY_RUN=1 ./sh/stake-and-delegate.sh",
    "op:plan:stake-delegate": "WRITE_PLAN=1 ./sh/stake-and-delegate.sh",
    "op:delegate-equal": "./sh/delegate-equal.sh",
    "op:sim:delegate-equal": "DRY_RUN=1 ./sh/delegate-equal.sh",
    "op:plan:delegate-equal": "WRITE_PLAN=1 ./sh/delegate-equal.sh",
    "op:redelegate": "./sh/redelegate.sh",
    "op:sim:redelegate": "DRY_RUN=1 ./sh/redelegate.sh",
    "op:plan:redelegate": "WRITE_PLAN=1 ./sh/redelegate.sh",
    "op:wrap": "./sh/wrap-governance.sh",
    "op:sim:wrap": "DRY_RUN=1 ./sh/wrap-governance.sh",
    "op:treasury": "./sh/treasury.sh",
    "op:sim:treasury": "DRY_RUN=1 ./sh/treasury.sh",
    "test:forge": "forge test",
    "test:foundry": "forge test"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
